# Ignore all files by default
*

# Allow workflows
!/.github/
!/.github/workflows/
!/.github/workflows/*.yml

# Include specific files
!*.R
!*.txt
!*.xlsx
!*.rds
!README.md
!Logos/**

# Allow Firebase
!/firebase.json
!/.firebaserc

# Explicitly ignore directories we don't want to track
/docs/
/Dropbox/
/Actas/
/cache_backup/
/scratch/
.Rproj.user/
.positai/

# Explicitly ignore cache and system files
*.RData
*.Rdata
.DS_Store
.Rhistory
.Ruserdata
*.Rproj
